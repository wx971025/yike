<Page
    x:Class="YiKe.Desktop.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyDown="Page_KeyDown">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="今日复习" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="刷新" Click="Refresh_Click" />
            <TextBlock Text="{x:Bind ViewModel.ToastMessage, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="IndianRed" TextWrapping="Wrap" />
            <ProgressBar Minimum="0"
                         Maximum="{x:Bind ViewModel.ProgressTotal, Mode=OneWay}"
                         Value="{x:Bind ViewModel.ProgressStep, Mode=OneWay}"
                         Visibility="{x:Bind ViewModel.HasActiveReview, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.SelectSpellTabCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="拼写复习" />
                        <TextBlock Text="{x:Bind ViewModel.SpellCount, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.SelectRecognizeTabCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="认知复习" />
                        <TextBlock Text="{x:Bind ViewModel.RecognizeCount, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        MaxWidth="640"
                        Visibility="{x:Bind ViewModel.HasActiveReview, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                <StackPanel Visibility="{x:Bind ViewModel.IsSpellTab, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.CurrentWord.Meaning, Mode=OneWay}"
                               FontSize="24"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center" />
                    <TextBox PlaceholderText="输入单词"
                             Text="{x:Bind ViewModel.SpellInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SpellInput_KeyDown"
                             HorizontalAlignment="Stretch" />
                    <TextBlock Text="{x:Bind ViewModel.SpellErrorMessage, Mode=OneWay}"
                               Foreground="IndianRed"
                               Visibility="{x:Bind ViewModel.SpellHasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Button Content="确认拼写" Command="{x:Bind ViewModel.SubmitSpellCommand}" />
                        <Button Content="查看答案" Command="{x:Bind ViewModel.PeekSpellAnswerCommand}" />
                        <Button Content="跳过" Command="{x:Bind ViewModel.SkipCurrentCommand}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Visibility="{x:Bind ViewModel.IsRecognizeTab, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="12">
                    <TextBlock Text="{x:Bind ViewModel.CurrentWord.Word, Mode=OneWay}"
                               FontSize="32"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Visibility="{x:Bind ViewModel.MeaningRevealed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}" />
                    <TextBlock Text="先回忆中文释义，按 Enter 或 Space 显示"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind ViewModel.MeaningRevealed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}" />

                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.MeaningRevealed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.CurrentWord.Meaning, Mode=OneWay}"
                                   FontSize="24"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   Foreground="#FF047857" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentWord.Phonetic, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button x:Name="KnownButton"
                                    Content="熟知"
                                    Command="{x:Bind ViewModel.RecognizeKnownCommand}" />
                            <Button x:Name="ForgotButton"
                                    Content="忘记"
                                    Command="{x:Bind ViewModel.RecognizeForgotCommand}" />
                            <Button Content="跳过" Command="{x:Bind ViewModel.SkipCurrentCommand}" />
                        </StackPanel>
                        <TextBlock Text="Enter/Space 操作按钮，←/→ 切换焦点"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <Button Content="显示释义"
                            HorizontalAlignment="Center"
                            Command="{x:Bind ViewModel.RevealMeaningCommand}"
                            Visibility="{x:Bind ViewModel.MeaningRevealed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}" />
                </StackPanel>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.HasActiveReview, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                <TextBlock Text="🌙" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.EmptyStateText, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
