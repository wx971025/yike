<Page
    x:Class="YiKe.Desktop.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="48">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="420" Width="420">
            <TextBlock Text="忆刻 YiKe" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="Windows 原生客户端" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />

            <TextBox Header="用户名" Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <PasswordBox Header="密码" PasswordChanged="PasswordBox_PasswordChanged" />

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="IndianRed" TextWrapping="Wrap" />

            <Button Content="登录"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.LoginCommand}"
                    CommandParameter="{x:Bind Shell, Mode=OneWay}" />

            <HyperlinkButton Content="没有账号？注册" Click="GoRegister_Click" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
