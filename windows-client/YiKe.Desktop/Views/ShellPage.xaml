<Page
    x:Class="YiKe.Desktop.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <NavigationView x:Name="NavView"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="LeftCompact"
                    SelectionChanged="NavView_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="今日复习" Tag="dashboard" Icon="Home" IsSelected="True" />
            <NavigationViewItem Content="单词" Tag="words" Icon="Dictionary" />
            <NavigationViewItem Content="设置" Tag="settings" Icon="Setting" />
        </NavigationView.MenuItems>

        <NavigationView.PaneFooter>
            <StackPanel Spacing="8" Padding="12">
                <TextBlock Text="{x:Bind ViewModel.Username, Mode=OneWay}" TextWrapping="Wrap" />
                <Button Content="退出登录" Click="Logout_Click" HorizontalAlignment="Stretch" />
            </StackPanel>
        </NavigationView.PaneFooter>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
